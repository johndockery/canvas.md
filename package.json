    "@hono/node-server": "^1.19.11",
    "@milkdown/kit": "^7.18.0",
    "@milkdown/plugin-collab": "^7.18.0",
    "@milkdown/react": "^7.18.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@types/marked": "^5.0.2",
    "hono": "^4.12.5",
    "marked": "^17.0.3",
    "next": "^16.1.6",
    "pg": "^8.13.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
