# Anthropic API key used for AI chat and editing features.
ANTHROPIC_API_KEY=your-anthropic-api-key

# WebSocket URL for the Hocuspocus collaboration server.
NEXT_PUBLIC_COLLAB_URL=ws://localhost:1234

# PostgreSQL connection string used by the app and collaboration server.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/canvas

# Public base URL for the main web app.
CANVAS_PUBLIC_URL=http://localhost:3000

# Port used by the collaboration/MCP server process.
PORT=1234

# Optional GitHub token for server-side GitHub API access.
GITHUB_TOKEN=your-github-token
